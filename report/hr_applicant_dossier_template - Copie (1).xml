<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="print_report_alten">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-set="company" t-value="env.company"/>
                <t t-set="rows" t-value="get_rows(docs[0])"/>

                <div class="page">
                    <div class="alten-section-header">
                        <div class="alten-section-title fw-bold fs-3">
                            Compétences, technologies &amp; secteurs d'intervention
                        </div>

                        <div class="alten-stripes" aria-hidden="true">
                            <span class="s-red"></span>
                            <span class="s-blue"></span>
                            <span class="s-yellow"></span>
                        </div>
                    </div>
                    <table class="alten-table">
                        <t t-foreach="rows" t-as="r">
                            <tr>
                                <td class="alten-label"><t t-esc="r['label']"/></td>
                                <td class="alten-value"><t t-esc="r['value']"/></td>
                            </tr>
                        </t>
                    </table>



                    <div class="alten-section-header">
                        <div class="alten-section-title fw-bold fs-3">
                            Formation, habilitations &amp; langues
                        </div>

                        <div class="alten-stripes" aria-hidden="true">
                            <span class="s-red"></span>
                            <span class="s-blue"></span>
                            <span class="s-yellow"></span>
                        </div>
                    </div>

                    <table class="alten-table">
                        <!-- FORMATION -->
                        <tr>
                            <td class="alten-label">Formation</td>

                            <!-- VALUE CELL -->
                            <td class="alten-value">
                                <ul class="alten-list">
                                    <t t-foreach="docs[0].dossier_formation_ids" t-as="f">
                                        <li>
                                            <t t-esc="f.title" />
                                        </li>
                                    </t>
                                </ul>
                            </td>

                            <!-- DATE CELL -->
                            <td class="alten-value alten-date">
                                <ul class="alten-list">
                                    <t t-foreach="docs[0].dossier_formation_ids" t-as="f">
                                        <li>
                                            <t t-if="f.start">
                                                <t t-esc="f.start.strftime('%b %Y')" />
                                            </t>
                                            <t t-if="f.start or f.end"> - </t>
                                            <t t-if="f.end">
                                                <t t-esc="f.end.strftime('%b %Y')" />
                                            </t>
                                        </li>
                                    </t>
                                </ul>
                            </td>
                        </tr>

                        <!-- HABILITATIONS -->
                        <tr>
                            <td class="alten-label">Habilitations</td>

                            <td class="alten-value">
                                <ul class="alten-list">
                                    <t t-foreach="docs[0].dossier_habilitation_ids" t-as="h">
                                        <li>
                                            <t t-esc="h.title" />
                                        </li>
                                    </t>
                                </ul>
                            </td>

                            <td class="alten-value alten-date">
                                <!-- empty (as template) -->
                            </td>
                        </tr>
                    </table>
                    


                    <div class="alten-section-header">
                        <div class="alten-section-title fw-bold fs-3">
                            Projets, réalisations &amp; responsabilités
                        </div>

                        <div class="alten-stripes" aria-hidden="true">
                            <span class="s-red"></span>
                            <span class="s-blue"></span>
                            <span class="s-yellow"></span>
                        </div>
                    </div>

                    <div>
                        <t t-foreach="docs[0].dossier_experience_ids.sorted('sequence')" t-as="exp">
                            <div class="exp-block mb-5">
                                <!-- EXPERIENCE TITLE LINE -->
                                <div class="d-flex justify-content-between align-items-baseline mb-2 exp-header">
                                    <div class="fw-bold fs-5">
                                        <t t-esc="exp.company or ''"/>
                                    </div>

                                    <div class="fw-bold fs-5">
                                        <t t-if="exp.start">
                                            <t t-esc="exp.start.strftime('%b %Y')"/>
                                        </t>
                                        <t t-if="exp.start or exp.end"> – </t>
                                        <t t-if="exp.end">
                                            <t t-esc="exp.end.strftime('%b %Y')"/>
                                        </t>
                                        <t t-if="not exp.end">Aujourd’hui</t>
                                    </div>
                                </div>

                                <hr class="hr"/>
                                
                                <div class="d-flex align-items-start exp-inline">
                                        <div class="fw-bold me-2">
                                            Contexte général :
                                        </div>
                                    <t t-if="exp.contexte"><div class="exp-inline-value flex-grow-1"><t t-out="exp.contexte"/></div>
                                    </t>
                                </div>

                                <div class="d-flex align-items-start exp-inline">
                                    <div class="fw-bold me-2 flex-shrink-0">
                                        Sujet du projet :
                                    </div>
                                    <t t-if="exp.sujet">
                                        <div class="exp-inline-value flex-grow-1">
                                            <t t-out="exp.sujet" />
                                        </div>
                                    </t>
                                </div>

                                <div class="d-flex align-items-start exp-inline">
                                    <div class="fw-bold me-2 flex-shrink-0">
                                        Responsabilités occupées :
                                    </div>
                                    <t t-if="exp.responsabilites">

                                        <div class="exp-inline-value flex-grow-1">
                                            <t t-out="exp.responsabilites" />
                                        </div>
                                    </t>
                                </div>

                                <div class="d-flex align-items-start exp-inline">
                                    <div class="fw-bold me-2 flex-shrink-0">
                                        Travail réalisé :
                                    </div>
                                    <t t-if="exp.travail">

                                        <div class="exp-inline-value flex-grow-1">
                                            <t t-out="exp.travail" />
                                        </div>
                                    </t>
                                </div>

                                <div class="d-flex align-items-start exp-inline">
                                    <div class="fw-bold me-2 flex-shrink-0">
                                        Résultats obtenus :
                                    </div>
                                    <t t-if="exp.resultats">

                                        <div class="exp-inline-value flex-grow-1">
                                            <t t-out="exp.resultats" />
                                        </div>
                                    </t>
                                </div>
                                
                                <div class="exp-inline">
                                    <!-- ========================= -->
                                    <!-- Environnement technique -->
                                    <!-- ========================= -->

                                    <t t-set="all_types"
                                        t-value="env['hr.skill.type'].search([], order='sequence, name')"/>

                                    <t t-set="lines" t-value="exp.competency_line_ids"/>

                                    <t t-set="first_type" t-value="all_types[:1]"/>
                                    <t t-set="rest_types" t-value="all_types[1:]"/>

                                    <table class="table table-sm mt-2 exp-envtech-table">

                                        <!-- First row (contains the rowspan cell) -->
                                        <t t-foreach="first_type" t-as="st">
                                            <tr>
                                                <td class="alten-label envtech-cell" style="width: 22%;" t-att-rowspan="len(all_types) or 1">
                                                    Environnement<br/>technique
                                                </td>

                                                <td class="alten-label" style="width: 28%;">
                                                    <t t-esc="st.name"/>
                                                </td>

                                                <td class="alten-value" style="width: 50%;">
                                                    <t t-set="matched"
                                                    t-value="lines.filtered(lambda l: l.skill_id and l.skill_id.skill_type_id == st)"/>

                                                    <t t-if="matched">
                                                        <t t-foreach="matched" t-as="ln">
                                                            <t t-esc="ln.skill_id.name"/>
                                                            <!-- <t t-if="ln.skill_level_id">
                                                                (<t t-esc="ln.skill_level_id.name"/>)
                                                            </t> -->
                                                            <t t-if="ln_index != len(matched) - 1">, </t>
                                                        </t>
                                                    </t>
                                                    <t t-else="">&#8212;</t>
                                                </td>
                                            </tr>
                                        </t>

                                        <!-- Remaining rows -->
                                        <t t-foreach="rest_types" t-as="st">
                                            <tr>
                                                <td class="alten-label">
                                                    <t t-esc="st.name"/>
                                                </td>

                                                <td class="alten-value">
                                                    <t t-set="matched"
                                                    t-value="lines.filtered(lambda l: l.skill_id and l.skill_id.skill_type_id == st)"/>

                                                    <t t-if="matched">
                                                        <t t-foreach="matched" t-as="ln">
                                                            <t t-esc="ln.skill_id.name"/>
                                                            <!-- <t t-if="ln.skill_level_id">
                                                                (<t t-esc="ln.skill_level_id.name"/>)
                                                            </t> -->
                                                            <t t-if="ln_index != len(matched) - 1">, </t>
                                                        </t>
                                                    </t>
                                                    <t t-else="">&#8212;</t>
                                                </td>
                                            </tr>
                                        </t>

                                    </table>



                                </div>
                                
                            </div>
                        </t>
                    </div>

                </div>

            </t>
        </t>
    </template>

    
</odoo>
