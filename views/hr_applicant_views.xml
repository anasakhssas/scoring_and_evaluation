<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_applicant_job_extraction_wizard_form" model="ir.ui.view">
        <field name="name">applicant.job.extraction.wizard.form</field>
        <field name="model">applicant.job.extraction.wizard</field>
        <field name="arch" type="xml">
            <form string="Extracted Job Data" create="0" edit="0" delete="0">
                <group>
                    <field name="applicant_id"/>
                </group>
                <group>
                    <field name="extracted_data" widget="text" nolabel="1"/>
                </group>
                <footer>
                    <button string="Close" class="btn-primary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hr_applicant_view_form_inherit_extraction_button" model="ir.ui.view">
        <field name="name">hr.applicant.form.inherit.extraction.button</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button
                    name="action_show_extracted_job_data"
                    string="Show Extracted Job Data"
                    type="object"
                    class="oe_highlight"
                    invisible="not id"
                />
            </xpath>
        </field>
    </record>
</odoo>
